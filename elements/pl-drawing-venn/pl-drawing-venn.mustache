{{#render_button}}
<button type="button" name="{{button_class}}" class="btn btn-primary pl-drawing-button tooltip-container" opts="{{{ options }}}"><h3 class="button-header"><i class="{{icon}}"></i></h3><span class="tooltip-text">{{tooltip}}</span></button>
{{/render_button}}

{{#uuid}}

<div id="pl-drawing-venn-{{uuid}}" class="pl-drawing-container">
  {{#editable}}
  <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1080">
    <div class="toast align-items-center text-bg-primary border-0 venn-toast" role="status" aria-live="polite" aria-atomic="true">
      <div class="d-flex">
        <div class="toast-body"></div>
        <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
      </div>
    </div>
  </div>
  {{/editable}}
  <div class="pl-drawing-main">
    <div class="venn-diagram-score-badge-wrapper">
    {{#parse_error}}
        <a
          role="button"
          class="btn btn-light border d-flex align-items-center text-danger"
          data-bs-toggle="popover"
          data-bs-html="true"
          title="Invalid Diagram"
          data-bs-placement="auto"
          data-bs-trigger="focus"
          tabindex="0"
          data-bs-content="{{parse_error}}"
          style="max-width: 100px; margin-bottom: 0px;"
        >
        <span class="me-1">Invalid</span> <i class="fa fa-exclamation-triangle" aria-hidden="true"></i>
        </a>
      {{/parse_error}}
      {{#show_score_badge}}
        {{#is_100}}
          <span class="badge text-bg-success">
              <i class="fa fa-check" aria-hidden="true"></i> 100%
          </span>
        {{/is_100}}
        {{#is_0}}
          <span class="badge text-bg-danger" style="margin: 0px;">
            <i class="fa fa-times" aria-hidden="true"></i> 0%
          </span>
        {{/is_0}}
      {{/show_score_badge}}
      </div>
    
    {{#show_canvas}}
    <div class="pl-drawing-canvas-wrapper">
        {{#help_text}}
        <button
          type="button"
          class="btn btn-primary venn-instructions-button"
          data-venn-instructions-toggle="true"
          aria-label="Venn diagram instructions"
          aria-expanded="false"
        >
          <i class="bi bi-info-lg" aria-hidden="true"></i>
        </button>
        <div class="venn-instructions-panel d-none" role="dialog" aria-modal="true" aria-labelledby="venn-instructions-title-{{uuid}}">
          <div class="venn-instructions-panel-header">
            <h5 id="venn-instructions-title-{{uuid}}">Venn Diagram Instructions</h5>
            <button type="button" class="btn-close" data-venn-instructions-close="true" aria-label="Close"></button>
          </div>
          <div class="venn-instructions-panel-body">
            <p>Actions:</p>
            <ul class="instructions-list">
            {{#button_data}}
            {{^disabled}}
              <li>{{{text}}}{{#show_button_hint}} <i class="{{icon}}"></i> button.{{/show_button_hint}}</li>
            {{/disabled}}
            {{/button_data}}
            </ul>
            <p class="mt-3">The Venn Diagram will only be graded as correct if:</p>
            <ul class="instructions-list">
              {{#insert}}<li>The correct number of circles are present in the diagram.</li>{{/insert}}
              {{#label}}<li>All circles are correctly labeled.</li>{{/label}}
              {{#shade}}<li>All regions are shaded correctly.</li>{{/shade}}
            </ul>
          </div>
        </div>
        {{/help_text}}
        <canvas width="500" height="500" id = "drawing_element"> </canvas>
        {{#submission}}
        {{#feedback}}
        <div class="pl-drawing-venn-feedback">
        <p>Feedback: {{{feedback}}}</p> </div>
        {{/feedback}}
        {{/submission}}
    </div>
    {{/show_canvas}}
  </div>
    
    {{#editable}}
        <input type="hidden" name="{{name}}">
    {{/editable}}
    {{#show_buttons}}
        <div class="pl-drawing-sidebar">
            {{{btn_markup}}}
        </div>
    {{/show_buttons}}
</div>

<script>
 (function() {
     let element = document.getElementById("pl-drawing-venn-{{uuid}}");
     let options = JSON.parse(`{{{options_json}}}`);
     let drawingApiInstance = new PLDrawingVennApi();
     {{^input_answer}}
     let submitted_answer = null;
     {{/input_answer}}
     {{#input_answer}}
     let submitted_answer = JSON.parse(`{{{input_answer}}}`);
     {{/input_answer}}
     $(function() {
        setupCanvas(drawingApiInstance, element, options, submitted_answer);
     });
 })();
</script>
{{/uuid}}
